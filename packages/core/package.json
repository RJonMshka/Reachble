{
  "name": "@reachble/core",
  "version": "0.1.0",
  "description": "VEX generator for npm/JS/TS projects backed by reachability analysis",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "reachble": "./dist/cli.cjs"
  },
  "files": ["dist"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "lint": "eslint src --max-warnings 0 && prettier --check src",
    "lint:fix": "eslint src --fix && prettier --write src"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.10.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT"
}
